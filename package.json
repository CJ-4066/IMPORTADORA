{
  "name": "catalogo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "PORT=${PORT:-4000} HOSTNAME=0.0.0.0 next start",
    "lint": "eslint .",
    "test:assistant": "node --import tsx --test src/lib/shop-assistant.test.ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:sync-categories": "tsx prisma/sync-categories.ts",
    "sync:facturador-product": "tsx prisma/sync-facturador-product.ts",
    "sync:facturador-products": "tsx prisma/sync-facturador-products.ts",
    "sync:facturador-scheduler": "tsx prisma/erp-sync-scheduler.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "^6.19.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
