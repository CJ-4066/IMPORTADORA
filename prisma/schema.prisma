generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USERSHOP
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

enum TrendPeriod {
  WEEK
  MONTH
  YEAR
}

enum TrendDirection {
  RISING
  FALLING
  STABLE
}

enum ErpSyncTrigger {
  MANUAL
  SCRIPT
  AUTOMATIC
}

enum ErpSyncStatus {
  RUNNING
  SUCCESS
  ERROR
  CANCELED
}

enum QuoteStatus {
  PENDING
  ERP_REGISTERED
  ERROR
}

enum ComplaintType {
  RECLAMO
  QUEJA
}

enum ComplaintStatus {
  NEW
  IN_REVIEW
  RESPONDED
  CLOSED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?  @db.VarChar(32)
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  quotes       Quote[]  @relation("UserQuotes")
}

model Product {
  id              String         @id @default(cuid())
  code            String         @unique @db.VarChar(64)
  slug            String         @unique @db.VarChar(140)
  name            String         @db.VarChar(180)
  description     String?        @db.Text
  technicalSpecs  String?        @db.Text
  brand           String?        @db.VarChar(120)
  category        String?        @db.VarChar(120)
  categoryId      String?
  categoryRef     Category?      @relation("CategoryToProduct", fields: [categoryId], references: [id], onDelete: SetNull)
  imageUrl        String?        @db.Text
  unitLabel       String         @default("unidad") @db.VarChar(40)
  unitPrice       Decimal        @db.Decimal(10, 2)
  wholesalePrice  Decimal?       @db.Decimal(10, 2)
  wholesaleMinQty Int            @default(3)
  boxPrice        Decimal?       @db.Decimal(10, 2)
  unitsPerBox     Int?
  stockUnits      Int            @default(0)
  isVisible       Boolean        @default(true)
  isFeatured      Boolean        @default(false)
  externalSource  String?        @db.VarChar(80)
  externalId      String?        @db.VarChar(120)
  externalCode    String?        @db.VarChar(120)
  syncEnabled     Boolean        @default(false)
  lastSyncedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  media           ProductMedia[]
  quoteItems      QuoteItem[]    @relation("ProductQuoteItems")

  @@index([name])
  @@index([code])
  @@index([category, isVisible])
  @@index([brand, isVisible])
  @@index([isVisible, updatedAt(sort: Desc)])
  @@index([stockUnits])
  @@index([categoryId])
  @@index([externalSource, externalId])
  @@index([externalSource, externalCode])
  @@index([syncEnabled, lastSyncedAt])
}

model ProductMedia {
  id        String           @id @default(cuid())
  productId String
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ProductMediaType
  url       String           @db.Text
  altText   String?          @db.VarChar(180)
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([productId, sortOrder])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique @db.VarChar(120)
  slug      String    @unique @db.VarChar(140)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[] @relation("CategoryToProduct")

  @@index([name])
}

model StoreSettings {
  id                  Int      @id @default(1)
  businessName        String   @default("Importaciones Super")
  heroTitle           String   @default("Catálogo mayorista con pedido directo por WhatsApp")
  heroDescription     String   @default("Explora el stock disponible, arma tu pedido y envíalo en segundos sin llamadas ni pasos innecesarios.")
  heroSlides          Json?
  heroAutoplaySeconds Int      @default(5)
  whatsappNumber      String   @default("51999999999")
  orderIntro          String   @default("Hola, quiero cotizar estos productos:")
  orderFooter         String   @default("Quedo atento a la confirmación de stock y total final.")
  currencySymbol      String   @default("S/")
  highlightMessage    String   @default("Precios por unidad y mayorista sincronizados con el ERP.")
  supportHours        String   @default("Lun a sáb 8:00 am - 7:00 pm")
  primaryColor        String   @default("#0b86d1")
  accentColor         String   @default("#0b86d1")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Quote {
  id                     String      @id @default(cuid())
  userId                 String?
  user                   User?       @relation("UserQuotes", fields: [userId], references: [id], onDelete: SetNull)
  status                 QuoteStatus @default(PENDING)
  quoteNumber            String?     @db.VarChar(80)
  erpExternalId          String?     @db.VarChar(120)
  erpCustomerId          Int?
  erpCustomerMode        String?     @db.VarChar(40)
  customerName           String      @db.VarChar(180)
  customerPhone          String      @db.VarChar(32)
  customerEmail          String?     @db.VarChar(180)
  customerDocumentType   String?     @db.VarChar(20)
  customerDocumentNumber String?     @db.VarChar(40)
  customerAddress        String?     @db.Text
  currencySymbol         String      @default("S/") @db.VarChar(8)
  total                  Decimal     @db.Decimal(12, 2)
  note                   String?     @db.Text
  errorMessage           String?     @db.Text
  statusSteps            Json?
  pdfNotification        Json?
  whatsappHref           String?     @db.Text
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  items                  QuoteItem[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([quoteNumber])
  @@index([customerPhone])
  @@index([customerEmail])
}

model QuoteItem {
  id         String   @id @default(cuid())
  quoteId    String
  quote      Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation("ProductQuoteItems", fields: [productId], references: [id], onDelete: SetNull)
  code       String   @db.VarChar(64)
  externalId String?  @db.VarChar(120)
  name       String   @db.VarChar(180)
  quantity   Int
  unitPrice  Decimal  @db.Decimal(10, 2)
  total      Decimal  @db.Decimal(12, 2)
  tierLabel  String   @db.VarChar(40)
  createdAt  DateTime @default(now())

  @@index([quoteId])
  @@index([productId])
  @@index([code])
}

model Complaint {
  id               String          @id @default(cuid())
  claimCode        String          @unique @db.VarChar(40)
  kind             ComplaintType   @default(RECLAMO)
  subject          String          @db.VarChar(80)
  customerName     String          @db.VarChar(180)
  customerPhone    String?         @db.VarChar(32)
  customerEmail    String?         @db.VarChar(180)
  documentType     String?         @db.VarChar(20)
  documentNumber   String?         @db.VarChar(40)
  orderNumber      String?         @db.VarChar(80)
  productReference String?         @db.VarChar(120)
  detail           String          @db.Text
  status           ComplaintStatus @default(NEW)
  responseText     String?         @db.Text
  responseChannel  String?         @db.VarChar(20)
  respondedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([customerEmail])
  @@index([customerPhone])
}

model SalesTrendSnapshot {
  id          String      @id @default(cuid())
  period      TrendPeriod
  periodLabel String      @db.VarChar(50)
  periodStart DateTime
  periodEnd   DateTime
  revenue     Decimal     @db.Decimal(12, 2)
  orders      Int
  unitsSold   Int
  forecast    Decimal     @db.Decimal(12, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([period, periodStart(sort: Desc)])
}

model ProductTrendSnapshot {
  id            String         @id @default(cuid())
  period        TrendPeriod
  periodLabel   String         @db.VarChar(50)
  productCode   String         @db.VarChar(64)
  productName   String         @db.VarChar(180)
  unitsSold     Int
  deltaPercent  Decimal        @db.Decimal(8, 2)
  momentumScore Decimal        @db.Decimal(8, 2)
  direction     TrendDirection
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([period, direction])
  @@index([period, momentumScore(sort: Desc)])
}

model ErpSyncLog {
  id                String         @id @default(cuid())
  source            String         @db.VarChar(80)
  trigger           ErpSyncTrigger @default(SCRIPT)
  status            ErpSyncStatus  @default(RUNNING)
  fetchedCount      Int            @default(0)
  createdCount      Int            @default(0)
  updatedCount      Int            @default(0)
  skippedCount      Int            @default(0)
  skippedPreview    Json?
  errorMessage      String?        @db.Text
  cancelRequestedAt DateTime?
  initiatedByName   String?        @db.VarChar(120)
  initiatedByEmail  String?        @db.VarChar(180)
  canceledByName    String?        @db.VarChar(120)
  canceledByEmail   String?        @db.VarChar(180)
  startedAt         DateTime       @default(now())
  finishedAt        DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
